#!/usr/bin/env bash
# deck-grid <project>
# Open the 6-pane workspace for ONE project, its bus tailing in pane 5. Same layout idea
# as the mesh grid, but every pane is scoped to this project's bus (DECK_PROJECT is set,
# and ask/relay take the project as their first arg). Switching projects = a new grid /
# a new global project — the "thumb scroll" dashboard is the later web layer.
set -euo pipefail
BIN="$(cd "$(dirname "$0")" && pwd)"
DECK="$(cd "$BIN/.." && pwd)"
PROJ="${1:?usage: deck-grid <project>}"
DIR="$("$BIN/bus" path "$PROJ")"
[ -d "$DIR" ] || { echo "no such project: $PROJ  (deck new $PROJ)" >&2; exit 1; }

SESSION="deck-$PROJ"
if tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "Session '$SESSION' already running.  Attach: tmux attach -t $SESSION"; exit 0
fi

tmux new-session -d -s "$SESSION" -c "$DECK"
P=( "$(tmux list-panes -t "$SESSION" -F '#{pane_id}' | head -1)" )
for _ in 1 2 3 4 5; do
  pid=$(tmux split-window -t "$SESSION" -c "$DECK" -P -F '#{pane_id}')
  tmux select-layout -t "$SESSION" tiled >/dev/null
  P+=( "$pid" )
done

seed(){ # seed <pane-id> <label>
  tmux send-keys -t "$1" "export PATH=\"$BIN:\$PATH\" DECK_PROJECT=\"$PROJ\"; clear; printf '\033[1;33m%s\033[0m\n\n' \"$2\"" C-m
}
seed "${P[0]}" "Pane 0 - Claude Code   (run: claude)"
seed "${P[1]}" "Pane 1 - DeepSeek      (ask $PROJ deepseek-v4-pro \"...\")"
seed "${P[2]}" "Pane 2 - GLM / Qwen    (ask $PROJ zai-org-glm-5 \"...\")"
seed "${P[3]}" "Pane 3 - Venice        (ask $PROJ venice-uncensored-1-2 \"...\")"
seed "${P[4]}" "Pane 4 - Infra / git   (your shell; run relay / bus decision here)"
tmux send-keys -t "${P[5]}" "export PATH=\"$BIN:\$PATH\"; clear; printf '\033[1;32m%s\033[0m\n' 'Pane 5 - BUS ($PROJ)'; \"$BIN/bus\" tail '$PROJ'" C-m

echo "Started '$SESSION' (project: $PROJ)."
echo "Attach:  tmux attach -t $SESSION      Detach: Ctrl-b then d      Kill: tmux kill-session -t $SESSION"
